# Prefixes

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ea-party: <http://environment.data.gov.uk/ontology/party/> .
@prefix ea-location: <http://environment.data.gov.uk/ontology/location/> .
@prefix ea-permit: <http://environment.data.gov.uk/ontology/permit/> .

ea-permit:permit-ontology rdf:type owl:Ontology ;
    dcterms:title "Permit ontology"@en ;
    dcterms:created "2025-06-25"^^xsd:date ;
    dcterms:modified "2026-07-01"^^xsd:date ;
    dcterms:rights "Open Government Licence"@en ;
    dcterms:description "A model describing discharge permits authorised by the Environment Agency."@en .

# Classes

ea-permit:Permit rdf:type owl:Class ;
    rdfs:label "Permit"@en ;
    rdfs:comment "A permit allocated to a permit holder to allow them to discharge into a waterbody at a specific point with certain constraints. The unique id for a permit should have no special characters."@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:Purpose rdf:type owl:Class ;
    rdfs:label "Purpose"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

# Object Properties

ea-permit:dischargePoint rdf:type owl:ObjectProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range ea-location:Location ;
    rdfs:label "dischargePoint"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:effluentType rdf:type owl:ObjectProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range ea-permit:EffluentTypeConcept ;
    rdfs:label "effluentType"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:associatedOperationalLocation rdf:type owl:ObjectProperty ;
    rdfs:domain ea-location:Location ;
    rdfs:range ea-permit:Waterbody ;
    rdfs:label "associatedOperationalLocation"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:monitoringPoint rdf:type owl:ObjectProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range ea-permit:Location ;
    rdfs:label "monitoringPoint"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:permitForSite rdf:type owl:ObjectProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range ea-permit:Site ;
    rdfs:label "permitForSite"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:permitHolder rdf:type owl:ObjectProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range ea-party:Party ;
    rdfs:label "permitHolder"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

# Datatype Properties

ea-permit:bodyText rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range xsd:string ;
    rdfs:label "bodyText"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:definition rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-permit:Concept ;
    rdfs:range xsd:string ;
    rdfs:label "definition"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:permitNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range xsd:string ;
    rdfs:label "permitNumber"@en ;
    rdfs:comment "The permit number as printed including special characters as would appear on the PDF."@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:revocationDate rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range xsd:date ;
    rdfs:label "revocationDate"@en ;
    rdfs:isDefinedBy ea-permit:permit-ontology .

ea-permit:startDate rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-permit:Permit ;
    rdfs:range xsd:date ;
    rdfs:label "startDate"@en .


# Property restrictions (example)

ea-permit:EffluentType a skos:ConceptScheme ;
    skos:notation "ea-permit/effluent-scheme" .

ea-permit:EffluentTypeConcept a owl:Class ;
    owl:intersectionOf (
        skos:Concept
        [
            a owl:Restriction ;
            owl:onProperty skos:inScheme ;
            owl:hasValue ea-permit:EffluentType
        ]
    ) .