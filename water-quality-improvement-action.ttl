# Prefixes

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ea-party: <http://environment.data.gov.uk/ontology/party/> .
@prefix ea-improvement-action: <http://environment.data.gov.uk/ontology/improvement-action/> .

ea-improvement-action:improvement-action-ontology rdf:type owl:Ontology ;
    dcterms:title "Water Improvement Action ontology"@en ;
    dcterms:created "2025-06-25"^^xsd:date ;
    dcterms:modified "2026-07-01"^^xsd:date ;
    dcterms:rights "Open Government Licence v3"@en ;
    dcterms:description "A model describing a the improvement actions from the Water Industry National Environment Programme commonly referenced by the Environment Agency."@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

# Classes

ea-improvement-action:Driver rdf:type owl:Class ;
    rdfs:label "Driver"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

# Object Properties

ea-improvement-action:action rdf:type owl:ObjectProperty ;
    rdfs:domain ea-improvement-action:Driver ;
    rdfs:label "action"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

ea-improvement-action:driver rdf:type owl:ObjectProperty ;
    rdfs:domain ea-improvement-action:Action ;
    rdfs:range ea-improvement-action:Driver ;
    rdfs:label "driver"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

ea-improvement-action:siteType rdf:type owl:ObjectProperty ;
    rdfs:domain ea-improvement-action:Site ;
    rdfs:range ea-improvement-action:SiteType ;
    rdfs:label "siteType"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

ea-improvement-action:waterCompany rdf:type owl:ObjectProperty ;
    rdfs:domain ea-improvement-action:Action ;
    rdfs:range ea-party:Party ;
    rdfs:label "waterCompany"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

# Datatype Properties

ea-improvement-action:completionDate rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-improvement-action:Action ;
    rdfs:range xsd:date ;
    rdfs:label "completionDate"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

ea-improvement-action:localAuthority rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-improvement-action:Site ;
    rdfs:range xsd:string ;
    rdfs:label "localAuthority"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .

ea-improvement-action:postcode rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-improvement-action:Site ;
    rdfs:range xsd:string ;
    rdfs:label "postcode"@en ;
    rdfs:isDefinedBy ea-improvement-action:improvement-action-ontology .