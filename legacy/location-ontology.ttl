
# Prefixes

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ea-party: <http://environment.data.gov.uk/ontology/party/>.
@prefix ea-location: <http://environment.data.gov.uk/ontology/location/> .

ea-location:location-ontology rdf:type owl:Ontology ;
    dcterms:title "Location ontology"@en ;
    dcterms:created "2025-06-25"^^xsd:date ;
    dcterms:modified "2026-07-01"^^xsd:date ;
    dcterms:rights "Open Government Licence v3"@en ;
    dcterms:description "A model describing the types of location commonly referenced by the Environment Agency."@en .

# Classes

ea-location:Location rdf:type owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:NamedLocation rdf:type owl:Class ;
    rdfs:subClassOf ea-location:Location ;
    rdfs:label "NamedLocation"@en ;
    rdfs:comment "A geographic location with a name. The name should come from a predefined naming convention where possible."@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:LocationWithOnlyExtent rdf:type owl:Class ;
    rdfs:subClassOf ea-location:Location ;
    rdfs:label "LocationWithOnlyExtent"@en ;
    rdfs:comment "A geographic location that will have some geographic extent but not intended to be used as a named or addressable. A single discharge or monitoring point for example might be given only as a point coordinate. "@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:OperationalLocation rdf:type owl:Class ;
    rdfs:subClassOf ea-location:Location ;
    rdfs:label "OperationalLocation"@en ;
    rdfs:comment "A geographically bounded region that serves as a functional unit for a specific organization, authority, or stakeholder to conduct operations, exercise jurisdiction, provide services, or manage resources within defined spatial limits."@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:AddressableLocation rdf:type owl:Class ;
    rdfs:subClassOf ea-location:NamedLocation ;
    rdfs:label "AddressableLocation"@en ;
    rdfs:comment "A geographic location that can be assigned an addresss. For example, a postal address or equivalent."@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

# Object Properties

ea-location:containedIn rdf:type owl:ObjectProperty ;
    rdfs:domain ea-location:OperationalLocation ;
    rdfs:range ea-location:OperationalLocation ;
    rdfs:label "containedIn"@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:associatedOperationalLocation rdf:type owl:ObjectProperty ;
    rdfs:domain ea-location:Location ;
    rdfs:range ea-location:OperationalLocation ;
    rdfs:label "associatedOperationalLocation"@en ;
    rdfs:comment "Associates in some way a Location with a OperationalLocation this allows for the loose but valuable association between places and an operational area."@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:siteType rdf:type owl:ObjectProperty ;
    rdfs:domain ea-location:Site ;
    rdfs:range ea-location:SiteType ;
    rdfs:label "siteType"@en ;
    rdfs:isDefinedBy ea-location:location-ontology .

ea-location:operationalLocationFor rdf:type owl:ObjectProperty ;
    rdfs:domain ea-location:OperationalLocation ;
    rdfs:range ea-party:Party ;
    rdfs:label "operationalLocationFor"@en ;
    rdfs:isDefinedBy ea-location:location-ontology .