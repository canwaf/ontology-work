@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix defra-core: <http://environment.data.gov.uk/ontology/core/> .
@prefix defra-reg: <http://environment.data.gov.uk/ontology/regulation/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://environment.data.gov.uk/ontology/regulation> a owl:Ontology ;
    dcterms:title "DEFRA Regulation Ontology"@en ;
    dcterms:description "Regulation reusable classes and properties for DEFRA Linked Data APIs, covering Permit, Condition, Limit, Breach, Driver, Action."@en ;
    dcterms:creator "Department for Environment, Food and Rural Affairs"@en ;
    dcterms:publisher "Department for Environment, Food and Rural Affairs"@en ;
    dcterms:license <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    dcterms:created "2026-07-01"^^xsd:date ;
    owl:versionInfo "0.1.0" ;
    rdfs:seeAlso <http://environment.data.gov.uk/catalog> ;
     .

defra-reg:Permit a owl:Class ;
    rdfs:subClassOf dcat:Resource ;
    rdfs:label "Permit"@en ;
    rdfs:comment "A regulatory permission that authorises one or more regulated activities and may subject to conditions."@en .

defra-reg:PermitDocument a owl:Class ;
    rdfs:subClassOf defra-core:Document ;
    rdfs:label "Permit Document"@en ;
    rdfs:comment "A document that records, issues, varies or describes a permit."@en .

defra-reg:Condition a owl:Class ;
    rdfs:label "Condition"@en ;
    rdfs:comment "A condition is allocated to a permit which qualifies the discharge with a specific constraint."@en ;
     .

defra-reg:Limit a owl:Class ;
    rdfs:subClassOf qudt:Quantity ;
    rdfs:label "Limit"@en ;
    rdfs:comment "A permitted range for a regulated property, expressed as an optional upper and/or lower bound quantity value. Intended to grow to handle rolling averages and nth percentile calculations."@en ;
     .

defra-reg:ProposedLimit a owl:Class ;
    rdfs:subClassOf defra-reg:Limit ;
    rdfs:label "Proposed Limit"@en ;
    rdfs:comment "A limit proposed by an improvement action that is not yet in force. Once the action matures it is expected to become a condition limit on the target permit."@en ;
     .

defra-reg:CarriedOverLimit a owl:Class ;
    rdfs:subClassOf defra-reg:ProposedLimit ;
    rdfs:label "Carried-Over Limit"@en ;
    rdfs:comment "A proposed limit that carries an existing permit condition forward unchanged (a continuance), rather than introducing a new bound."@en ;
     .

defra-reg:ConditionBreach a owl:Class ;
    rdfs:label "Condition Breach"@en ;
    rdfs:comment "A condition breach is allocated to a permit where limits set forth in conditions have been breached. A breach has an Applicability, a Condition breached, and has an evidenced set of Observations which resulted in the breach."@en ;
     .

defra-reg:ExceedanceBreach a owl:Class ;
    rdfs:subClassOf defra-reg:ConditionBreach ;
    rdfs:label "Exceedance Breach"@en ;
    rdfs:comment "A condition breach where an observed value exceeded the condition's upper bound."@en ;
     .

defra-reg:ShortfallBreach a owl:Class ;
    rdfs:subClassOf defra-reg:ConditionBreach ;
    rdfs:label "Shortfall Breach"@en ;
    rdfs:comment "A condition breach where an observed value fell below the condition's lower bound."@en ;
     .

defra-reg:Driver a owl:Class ;
    rdfs:label "Driver"@en ;
    rdfs:comment "To be defined."@en ;
     .

defra-reg:Action a owl:Class ;
    rdfs:label "Action"@en ;
    rdfs:comment "An improvement action carried out to address one or more drivers, located at a site, and which may propose new limits for a target permit. Has a completion date after which its proposed limits are expected to take effect."@en ;
     .

defra-reg:DischargePoint a owl:Class ;
    rdfs:label "Discharge Point"@en ;
    rdfs:comment "A point at which a discharge enters, or is authorised to enter, the environment."@en ;
    rdfs:subClassOf defra-core:Site .

# Object Properties

defra-reg:documentsPermit a owl:ObjectProperty ;
    rdfs:label "document permit"@en ;
    rdfs:domain defra-reg:PermitDocument ;
    rdfs:range defra-reg:Permit ;
    rdfs:subPropertyOf defra-core:about ;
     .

defra-reg:hasCondition a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:relation ;
    rdfs:label "has condition"@en ;
    rdfs:domain defra-reg:Permit ;
    rdfs:range defra-reg:Condition ;
     .

defra-reg:action a owl:ObjectProperty ;
    rdfs:label "action"@en ;
    rdfs:domain defra-reg:Driver ;
    rdfs:range defra-reg:Action ;
    owl:inverseOf defra-reg:driver ;
     .

defra-reg:driver a owl:ObjectProperty ;
    rdfs:label "driver"@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range defra-reg:Driver ;
    owl:inverseOf defra-reg:action ;
     .

defra-reg:permitHolder a owl:ObjectProperty ;
    rdfs:label "permit holder"@en ;
    rdfs:domain defra-reg:Permit ;
    rdfs:range defra-core:Party ;
     .

defra-reg:permitSite a owl:ObjectProperty ;
    rdfs:label "permit for site"@en ;
    rdfs:domain defra-reg:Permit ;
    rdfs:range defra-core:Site ;
     .

defra-reg:actionOwner a owl:ObjectProperty ;
    rdfs:label "action owner"@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range defra-core:Party ;
     .

defra-reg:actionSite a owl:ObjectProperty ;
    rdfs:label "action site"@en ;
    rdfs:comment "The site at which an improvement action is delivered."@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range defra-core:Site ;
     .

defra-reg:targetPermit a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:relation ;
    rdfs:label "target permit"@en ;
    rdfs:comment "The permit that an improvement action proposes to change."@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range defra-reg:Permit ;
     .

defra-reg:proposesLimit a owl:ObjectProperty ;
    rdfs:label "proposes limit"@en ;
    rdfs:comment "A new limit that this improvement action proposes for its target permit; not yet in force."@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range defra-reg:ProposedLimit ;
     .

defra-reg:continuesCondition a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:relation ;
    rdfs:label "continues condition"@en ;
    rdfs:comment "The in-force condition that this proposed limit carries forward unchanged."@en ;
    rdfs:domain defra-reg:ProposedLimit ;
    rdfs:range defra-reg:Condition ;
     .

defra-reg:hasLimit a owl:ObjectProperty ;
    rdfs:label "has limit"@en ;
    rdfs:domain defra-reg:Condition ;
    rdfs:range defra-reg:Limit ;
     .

defra-reg:regulatedProperty a owl:ObjectProperty ;
    rdfs:label "regulated property"@en ;
    rdfs:comment "The observable property (substance, parameter) that this condition or limit places a bound on."@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( defra-reg:Condition defra-reg:Limit ) ] ;
    rdfs:range sosa:ObservableProperty ;
     .

defra-reg:upperBound a owl:ObjectProperty ;
    rdfs:label "upper bound"@en ;
    rdfs:comment "The maximum permitted quantity value for a limit."@en ;
    rdfs:domain defra-reg:Limit ;
    rdfs:range qudt:QuantityValue ;
     .

defra-reg:lowerBound a owl:ObjectProperty ;
    rdfs:label "lower bound"@en ;
    rdfs:comment "The minimum permitted quantity value for a limit."@en ;
    rdfs:domain defra-reg:Limit ;
    rdfs:range qudt:QuantityValue ;
     .

defra-reg:evidencedByObservation a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:label "evidencing observations"@en ;
    rdfs:comment "Relates a condition breach to a (set of) observation(s) that provides evidence for the breach."@en ;
    rdfs:domain defra-reg:ConditionBreach ;
    rdfs:range sosa:Observation ;
     .

defra-reg:breachesCondition a owl:ObjectProperty ;
    rdfs:subPropertyOf dcterms:relation ;
    rdfs:label "breaches condition"@en ;
    rdfs:comment "Relates a condition breach to the permit condition that has been breached."@en ;
    rdfs:domain defra-reg:ConditionBreach ;
    rdfs:range defra-reg:Condition ;
     .

# Datatype Properties

defra-reg:completionDate a owl:DatatypeProperty ;
    rdfs:label "completion date"@en ;
    rdfs:domain defra-reg:Action ;
    rdfs:range xsd:date ;
     .

defra-reg:limitStatement a owl:DatatypeProperty ;
    rdfs:label "limit statement"@en ;
    rdfs:comment "A verbatim natural-language statement of a limit that has not been formalised into structured upper/lower bounds and requires human interpretation. Used to capture source text that cannot be parsed deterministically, in place of (or alongside) a quantity-value bound."@en ;
    rdfs:domain defra-reg:Limit ;
    rdfs:range xsd:string ;
     .