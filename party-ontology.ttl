# Prefixes

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ea-party: <http://environment.data.gov.uk/ontology/party/> .

ea-party:party-ontology rdf:type owl:Ontology ;
    dcterms:title "Party ontology"@en ;
    dcterms:created "2025-06-25"^^xsd:date ;
    dcterms:modified "2026-07-01"^^xsd:date ;
    dcterms:rights "Open Government Licence v3"@en ;
    dcterms:description "A model describing a the types of parties commonly referenced by the Environment Agency."@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

# Classes

ea-party:Party rdf:type owl:Class ;
    rdfs:label "Party"@en ;
    rdfs:comment "An individual or group who can act as agents. For example hold permits or commit to actions."@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

ea-party:Organisation rdf:type owl:Class ;
    rdfs:label "Organisation"@en ;
    rdfs:subClassof ea-party:Party ;
    rdfs:comment "Represents a collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organizations are often decomposable into hierarchical structures."@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

ea-party:IndustryClassification rdf:type owl:Class ;
    rdfs:label "IndustryClassification"@en ;
    rdfs:comment "A SIC code, or Standard Industrial Classification code, is a 5-digit number that classifies businesses by their economic activity. It's used to categorize companies for data collection, statistical analysis, and other government purposes. "@en ;
    rdfs:isDefinedBy ea-party:party-ontology .


# Object Properties

ea-party:industryClassficaion rdf:type owl:ObjectProperty ;
    rdfs:label "industryClassficaion"@en ;
    rdfs:comment "Indicates a unit which is part of this Organization, e.g. a Department within a larger Organization."@en ;
    rdfs:domain ea-party:Organisation ;
    rdfs:range ea-party:IndustryClassification ;
    rdfs:isDefinedBy ea-party:party-ontology .

ea-party:hasUnit rdf:type owl:ObjectProperty ;
    rdfs:domain ea-party:Organisation ;
    rdfs:range ea-party:Organisation ;
    rdfs:label "hasUnit"@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

# Datatype Properties

ea-party:companiesHouse rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-party:Organisation ;
    rdfs:range xsd:string ;
    rdfs:label "companiesHouse"@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

ea-party:contactPoint rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-party:Party ;
    rdfs:range xsd:string ;
    rdfs:label "contactPoint"@en ;
    rdfs:isDefinedBy ea-party:party-ontology .

ea-party:openCorporatesID rdf:type owl:DatatypeProperty ;
    rdfs:domain ea-party:Organisation ;
    rdfs:range xsd:string ;
    rdfs:label "openCorporatesID"@en ;
    rdfs:isDefinedBy ea-party:party-ontology .